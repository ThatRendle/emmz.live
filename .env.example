# Inbox owner details — used in magic-link emails
OWNER_NAME=Your Name
OWNER_EMAIL=you@example.com

# Comma-separated list of inbox slugs in the form {conf}/{talk}.
# Only these paths will be served; anything else returns 404.
# Example: two talks at the "cph" conference.
INBOXES=cph/hitc,cph/rtbc

# Resend API key for sending magic-link emails.
# Get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection string (Npgsql keyword form: Host=...;Database=...;Username=...;Password=...).
# Railway provides DATABASE_URL as a URL (postgres://user:pass@host:port/db); that form needs
# conversion to Npgsql keyword form — handled in the connection-setup section of the app.
DATABASE_URL=Host=localhost;Database=emmzlive;Username=emmzlive;Password=emmzlive

# Secret used to sign HMAC-SHA256 session tokens.
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string
