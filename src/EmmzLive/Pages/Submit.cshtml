@page "/{conf}/{talk}"
@model SubmitModel
@{
    ViewData["Title"] = "Submit a message";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        /* Mirrors the brand tokens in site.css — Layout=null means site.css is not loaded.
           Update both when changing the palette. */
        :root {
            --font:          "Outfit", system-ui, -apple-system, sans-serif;
            --bg:            #f7f5fc;
            --surface:       #ffffff;
            --text:          #1d1b2e;
            --muted:         #6b6880;
            --border:        #e4e0ee;
            --primary:       #7c3aed;
            --primary-hover: #6d28d9;
            --accent:        #14b8a6;
            --error:         #dc2626;
            --shadow:        0 2px 10px rgba(29, 27, 46, .08);
            --radius-sm:     0.375rem;
            --radius:        0.625rem;
            --radius-lg:     0.875rem;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.5rem 1rem;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            padding: 2rem 1.5rem;
            width: 100%;
            max-width: 480px;
        }

        h1 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1.25rem;
        }

        .field + .field { margin-top: 1rem; }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.375rem;
        }

        label .optional {
            font-weight: 400;
            color: var(--muted);
        }

        input[type="text"],
        textarea {
            display: block;
            width: 100%;
            font-size: 1rem;
            font-family: var(--font);
            padding: 0.625rem 0.75rem;
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            background: var(--surface);
            color: var(--text);
            transition: border-color .15s, box-shadow .15s;
            appearance: none;
        }

        input[type="text"]:focus,
        textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
        }

        textarea { resize: vertical; min-height: 8rem; }

        .validation-message {
            color: var(--error);
            font-size: 0.8125rem;
            margin-top: 0.3rem;
        }

        button[type="submit"] {
            margin-top: 1.5rem;
            width: 100%;
            padding: 0.75rem;
            font-size: 1rem;
            font-weight: 700;
            font-family: var(--font);
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: var(--radius);
            cursor: pointer;
            transition: background .15s;
        }

        button[type="submit"]:hover { background: var(--primary-hover); }
        button[type="submit"]:focus-visible {
            outline: 2px solid var(--primary);
            outline-offset: 2px;
        }

        .confirmation {
            margin-top: 1.25rem;
            padding: 0.875rem 1rem;
            background: #ecfdf5;
            border: 1.5px solid #6ee7b7;
            border-radius: var(--radius);
            font-weight: 600;
            color: #065f46;
        }

        .qr-section {
            margin-top: 2rem;
            text-align: center;
        }

        .qr-section p {
            font-size: 0.8125rem;
            color: var(--muted);
            margin-bottom: 0.75rem;
        }

        .qr-section img {
            max-width: 180px;
            height: auto;
            border-radius: var(--radius-sm);
        }

        .char-counter {
            display: block;
            text-align: right;
            font-size: 0.75rem;
            color: var(--muted);
            margin-top: 0.2rem;
        }

        .char-counter.at-limit {
            color: var(--error);
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Leave a message</h1>

        @if (Model.Submitted)
        {
            <div class="confirmation" role="status">
                @if (string.IsNullOrEmpty(Model.SubmittedSenderName))
                {
                    <text>Your message was sent anonymously. Thank you!</text>
                }
                else
                {
                    <text>Your message was sent as @Model.SubmittedSenderName. Thank you!</text>
                }
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="field">
                <label for="SenderName">Name <span class="optional">(optional)</span></label>
                <input type="text"
                       id="SenderName"
                       name="SenderName"
                       value="@Model.SenderName"
                       maxlength="64"
                       autocomplete="name"
                       placeholder="Your name (or leave blank to stay anonymous)" />
                <span asp-validation-for="SenderName" class="validation-message"></span>
                <span id="SenderName-counter" class="char-counter" aria-live="polite">[@((Model.SenderName ?? string.Empty).Length)/64]</span>
            </div>
            <div class="field">
                <label for="Body">Message</label>
                <textarea id="Body"
                          name="Body"
                          maxlength="512"
                          placeholder="Type your message here…">@Model.Body</textarea>
                <span asp-validation-for="Body" class="validation-message"></span>
                <span id="Body-counter" class="char-counter" aria-live="polite">[@(Model.Body.Length)/512]</span>
            </div>
            <button type="submit">Send</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.QrCodeBase64))
        {
            <div class="qr-section">
                <p>Share this page</p>
                <img src="data:image/png;base64,@Model.QrCodeBase64"
                     alt="QR code for this inbox"
                     width="180"
                     height="180" />
            </div>
        }
    </div>
    <script>
        (function () {
            var fields = [
                { fieldId: 'SenderName', counterId: 'SenderName-counter' },
                { fieldId: 'Body',       counterId: 'Body-counter' }
            ];
            fields.forEach(function (cfg) {
                var field   = document.getElementById(cfg.fieldId);
                var counter = document.getElementById(cfg.counterId);
                if (!field || !counter) return;
                function update() {
                    var n   = field.value.length;
                    var max = field.maxLength;
                    counter.textContent = '[' + n + '/' + max + ']';
                    if (n >= max) {
                        counter.classList.add('at-limit');
                    } else {
                        counter.classList.remove('at-limit');
                    }
                }
                field.addEventListener('input', update);
                update();
            });
        }());
    </script>
</body>
</html>
