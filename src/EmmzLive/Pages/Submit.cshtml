@page "/{conf}/{talk}"
@model SubmitModel
@{
    ViewData["Title"] = "Submit a message";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #f5f5f5;
            color: #1a1a1a;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.5rem 1rem;
        }

        .card {
            background: #fff;
            border-radius: 0.75rem;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            padding: 2rem 1.5rem;
            width: 100%;
            max-width: 480px;
        }

        h1 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1.25rem;
        }

        .field + .field { margin-top: 1rem; }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.375rem;
        }

        label .optional {
            font-weight: 400;
            color: #666;
        }

        input[type="text"],
        textarea {
            display: block;
            width: 100%;
            font-size: 1rem;
            font-family: inherit;
            padding: 0.625rem 0.75rem;
            border: 1.5px solid #d0d0d0;
            border-radius: 0.5rem;
            background: #fafafa;
            color: inherit;
            transition: border-color .15s;
        }

        input[type="text"]:focus,
        textarea:focus {
            outline: none;
            border-color: #4f6ef7;
            background: #fff;
        }

        textarea { resize: vertical; min-height: 8rem; }

        .validation-message {
            color: #c0392b;
            font-size: 0.8125rem;
            margin-top: 0.3rem;
        }

        button[type="submit"] {
            margin-top: 1.5rem;
            width: 100%;
            padding: 0.75rem;
            font-size: 1rem;
            font-weight: 700;
            font-family: inherit;
            background: #4f6ef7;
            color: #fff;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: background .15s;
        }

        button[type="submit"]:hover { background: #3a58d6; }
        button[type="submit"]:active { background: #2d46c2; }

        .confirmation {
            margin-top: 1.25rem;
            padding: 0.875rem 1rem;
            background: #eaf7ec;
            border: 1.5px solid #6fcf97;
            border-radius: 0.5rem;
            font-weight: 600;
            color: #1d6933;
        }

        .qr-section {
            margin-top: 2rem;
            text-align: center;
        }

        .qr-section p {
            font-size: 0.8125rem;
            color: #666;
            margin-bottom: 0.75rem;
        }

        .qr-section img {
            max-width: 180px;
            height: auto;
            border-radius: 0.375rem;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Leave a message</h1>

        @if (Model.Submitted)
        {
            <div class="confirmation" role="status">
                Your message was sent anonymously. Thank you!
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="field">
                <label for="SenderName">Name <span class="optional">(optional)</span></label>
                <input type="text"
                       id="SenderName"
                       name="SenderName"
                       value="@Model.SenderName"
                       maxlength="100"
                       autocomplete="name"
                       placeholder="Your name (or leave blank to stay anonymous)" />
                <span asp-validation-for="SenderName" class="validation-message"></span>
            </div>
            <div class="field">
                <label for="Body">Message</label>
                <textarea id="Body"
                          name="Body"
                          maxlength="5000"
                          placeholder="Type your message here…">@Model.Body</textarea>
                <span asp-validation-for="Body" class="validation-message"></span>
            </div>
            <button type="submit">Send anonymously</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.QrCodeBase64))
        {
            <div class="qr-section">
                <p>Share this page</p>
                <img src="data:image/png;base64,@Model.QrCodeBase64"
                     alt="QR code for this inbox"
                     width="180"
                     height="180" />
            </div>
        }
    </div>
</body>
</html>
