@page "/{conf}/{talk}/inbox"
@model InboxModel
@{
    ViewData["Title"] = "Inbox";
    Layout = "_ProjectorLayout";
}

<div class="projector-page">
    <div class="inbox-layout">
        <aside class="msg-list-panel">
            <div class="panel-header">
                <h1>Messages</h1>
                <span class="msg-count" id="msg-count" aria-live="polite">@Model.TotalCount</span>
            </div>
            <div id="msg-list"
                 hx-get="?handler=List"
                 hx-trigger="every 5s"
                 hx-swap="innerHTML">
                <partial name="_MessageList" model="Model" />
            </div>
        </aside>

        <main class="msg-detail-panel" id="msg-detail" aria-live="polite">
            <div class="detail-placeholder" id="detail-placeholder">
                <p>Select a message to read it.</p>
            </div>
            <div class="detail-content" id="detail-content" hidden>
                <p class="detail-sender" id="detail-sender"></p>
                <p class="detail-body" id="detail-body"></p>
            </div>
        </main>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // Tracks the id (string) of the currently selected message across HTMX refreshes.
    var selectedId = null;

    var list = document.getElementById('msg-list');
    var detailContent = document.getElementById('detail-content');
    var detailPlaceholder = document.getElementById('detail-placeholder');
    var detailSender = document.getElementById('detail-sender');
    var detailBody = document.getElementById('detail-body');

    function selectMessage(id, body, sender) {
        selectedId = id;

        // XSS-safe: textContent never interprets HTML.
        detailBody.textContent = body;
        detailSender.textContent = sender || '';
        detailSender.hidden = !sender;

        detailPlaceholder.hidden = true;
        detailContent.hidden = false;

        // Update visual selection state.
        list.querySelectorAll('.msg-item').forEach(function (el) {
            el.classList.toggle('selected', el.dataset.msgId === id);
        });
    }

    function getItems() {
        return Array.from(list.querySelectorAll('.msg-item'));
    }

    // Event delegation — one listener on the container so re-rendered items still work.
    list.addEventListener('click', function (e) {
        var item = e.target.closest('.msg-item');
        if (!item) return;
        selectMessage(item.dataset.msgId, item.dataset.msgBody, item.dataset.msgSender);
    });

    // After every HTMX swap: re-apply selected state to the new DOM nodes.
    list.addEventListener('htmx:afterSwap', function () {
        if (!selectedId) return;
        var items = getItems();
        var match = items.find(function (el) { return el.dataset.msgId === selectedId; });
        if (match) {
            match.classList.add('selected');
            // Keep detail panel as-is — message content has not changed.
        }
    });

    // Keyboard navigation: ArrowUp / ArrowDown.
    document.addEventListener('keydown', function (e) {
        if (e.key !== 'ArrowUp' && e.key !== 'ArrowDown') return;

        var items = getItems();
        if (items.length === 0) return;

        e.preventDefault();

        var currentIndex = selectedId
            ? items.findIndex(function (el) { return el.dataset.msgId === selectedId; })
            : -1;

        var nextIndex;
        if (e.key === 'ArrowDown') {
            // At the last item: stay put (boundary).
            nextIndex = currentIndex < items.length - 1 ? currentIndex + 1 : currentIndex;
            // Nothing selected yet: select the first item.
            if (currentIndex === -1) nextIndex = 0;
        } else {
            // ArrowUp: at the first item (or nothing selected): stay put.
            nextIndex = currentIndex > 0 ? currentIndex - 1 : 0;
            if (currentIndex === -1) nextIndex = 0;
        }

        var target = items[nextIndex];
        if (target) {
            selectMessage(target.dataset.msgId, target.dataset.msgBody, target.dataset.msgSender);
        }
    });
}());
</script>
}
